# --- LLM provider (required: set at least one key) ---
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Optional news API (falls back to free RSS if unset) ---
NEWSAPI_KEY=

# --- Data mode ---
# live   = pull real-time/delayed quotes via yfinance; auto-trades whichever of NSE/SGX/LSE/NYSE
#          is currently open (app/data/exchanges.py) and rolls over as markets close
# replay = replay cached recent historical intraday bars at accelerated speed, always the single
#          exchange named in REPLAY_EXCHANGE below, works any time (demo-friendly)
DATA_MODE=replay
REPLAY_EXCHANGE=NSE

# --- Database ---
DATABASE_URL=sqlite:///./investment_committee.db

# --- Trading session parameters ---
STARTING_CAPITAL_INR=10000
LEVERAGE=2
SESSION_HOURS=4
TICK_MINUTES=10
# How many symbols get the full 13-agent committee per tick - the main lever on how fast
# a decision lands (each symbol takes ~30-90s wall-clock), not TICK_MINUTES alone.
MAX_SYMBOLS_PER_TICK=1
WATCHLIST=RELIANCE.NS,TCS.NS,HDFCBANK.NS,INFY.NS,ICICIBANK.NS,LT.NS,SBIN.NS,ITC.NS,BHARTIARTL.NS,AXISBANK.NS,KOTAKBANK.NS,MARUTI.NS,SUNPHARMA.NS,TITAN.NS,ASIANPAINT.NS,BAJFINANCE.NS,HCLTECH.NS,WIPRO.NS

# Investment Planner's asset-allocation caps and profit/loss goals - conservative | moderate | aggressive
RISK_TOLERANCE=moderate

# --- Server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- Concurrency ---
# Caps concurrent LLM calls when agents run in parallel. Raise if your API tier
# comfortably handles more; too high trips rate limits and retries end up slower.
MAX_PARALLEL_AGENTS=4

# --- Optional: India macro data for the Macroeconomist Analyst's regime model ---
# No free live feed for these is wired up. Leave unset to use the news-sentiment-only
# reading, or fill in from RBI (repo rate) / MOSPI (GDP, CPI inflation) bulletins -
# they move slowly, so periodic manual updates are fine.
MACRO_GDP_GROWTH_PCT=
MACRO_INFLATION_PCT=
MACRO_POLICY_RATE_PCT=
MACRO_DATA_AS_OF=
